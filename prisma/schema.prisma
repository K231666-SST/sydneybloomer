generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentication ───────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────
enum UserRole {
  CUSTOMER
  ADMIN
  WHOLESALE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CUSTOMER)
  phone         String?
  company       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  inquiries     EventInquiry[]
  subscription  Subscription?
  adminLogs     AdminLog[]
  cart          CartItem[]
  wishlist      WishlistItem[]

  @@index([email])
}

// ─── Seasons & Categories ─────────────────────────────────────
enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  ALL_YEAR
}

model FlowerCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  flowers     Flower[]

  @@index([slug])
}

// ─── Flowers ─────────────────────────────────────────────────
enum FlowerOrigin {
  LOCAL
  IMPORTED
}

model Flower {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String?      @db.Text
  longDescription String?      @db.Text
  imageUrl        String
  images          String[]
  price           Decimal      @db.Decimal(10, 2)
  wholesalePrice  Decimal?     @db.Decimal(10, 2)
  unit            String       @default("stem")
  minOrderQty     Int          @default(1)
  wholesaleMinQty Int          @default(10)
  season          Season       @default(ALL_YEAR)
  origin          FlowerOrigin @default(LOCAL)
  country         String?
  color           String[]
  flowerType      String?
  occasion        String[]
  isFeatured      Boolean      @default(false)
  isActive        Boolean      @default(true)
  categoryId      String?
  category        FlowerCategory? @relation(fields: [categoryId], references: [id])
  inventory       FlowerInventory?
  orderItems      OrderItem[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  importDetails   ImportedFlower?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([slug])
  @@index([season])
  @@index([origin])
  @@index([isFeatured])
}

// ─── Inventory ────────────────────────────────────────────────
model FlowerInventory {
  id              String   @id @default(cuid())
  flowerId        String   @unique
  flower          Flower   @relation(fields: [flowerId], references: [id], onDelete: Cascade)
  quantity        Int      @default(0)
  reservedQty     Int      @default(0)
  lowStockThreshold Int    @default(20)
  nextRestockDate DateTime?
  restockQty      Int?
  updatedAt       DateTime @updatedAt

  @@index([flowerId])
}

// ─── Imported Flowers ─────────────────────────────────────────
model ImportedFlower {
  id               String   @id @default(cuid())
  flowerId         String   @unique
  flower           Flower   @relation(fields: [flowerId], references: [id], onDelete: Cascade)
  sourceCountry    String
  supplier         String?
  arrivalDay       String?
  arrivalFrequency String?
  shelfLifeDays    Int      @default(7)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
}

// ─── Orders ──────────────────────────────────────────────────
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DeliveryType {
  STANDARD
  EXPRESS
  SAME_DAY
  PICKUP
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  guestEmail      String?
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2) @default(0)
  discount        Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)
  deliveryType    DeliveryType @default(STANDARD)
  deliveryAddress String?     @db.Text
  deliveryDate    DateTime?
  notes           String?     @db.Text
  giftMessage     String?     @db.Text
  isWholesale     Boolean     @default(false)
  paymentId       String?
  paymentStatus   String?
  items           OrderItem[]
  delivery        Delivery?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  flowerId   String
  flower     Flower  @relation(fields: [flowerId], references: [id])
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  @@index([orderId])
}

// ─── Delivery ─────────────────────────────────────────────────
model Delivery {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNumber  String?
  carrier         String?
  estimatedDate   DateTime?
  actualDate      DateTime?
  recipientName   String?
  recipientPhone  String?
  suburb          String?
  state           String?
  postcode        String?
  instructions    String?  @db.Text
  signature       Boolean  @default(false)
}

// ─── Cart ─────────────────────────────────────────────────────
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flowerId  String
  flower    Flower   @relation(fields: [flowerId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, flowerId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flowerId  String
  flower    Flower   @relation(fields: [flowerId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, flowerId])
}

// ─── Events ──────────────────────────────────────────────────
enum EventType {
  WEDDING
  CORPORATE
  BIRTHDAY
  FUNERAL
  REAL_ESTATE
  RESTAURANT
  HOTEL
  OTHER
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CONFIRMED
  COMPLETED
  DECLINED
}

model EventInquiry {
  id            String        @id @default(cuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  fullName      String
  email         String
  phone         String?
  company       String?
  eventType     EventType
  eventDate     DateTime?
  guestCount    Int?
  venue         String?
  budget        String?
  description   String?       @db.Text
  status        InquiryStatus @default(NEW)
  adminNotes    String?       @db.Text
  quotedAmount  Decimal?      @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([eventType])
}

// ─── Subscriptions ────────────────────────────────────────────
enum SubFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum SubStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id])
  name        String
  frequency   SubFrequency @default(WEEKLY)
  budget      Decimal      @db.Decimal(10, 2)
  preferences String?      @db.Text
  address     String?      @db.Text
  status      SubStatus    @default(ACTIVE)
  nextDelivery DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── Gallery ─────────────────────────────────────────────────
enum GalleryCategory {
  WEDDING
  CORPORATE
  SEASONAL
  EVENTS
  STUDIO
}

model Gallery {
  id          String          @id @default(cuid())
  title       String?
  imageUrl    String
  category    GalleryCategory @default(STUDIO)
  description String?
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
}

// ─── Blog / CMS ──────────────────────────────────────────────
model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  imageUrl    String?
  tags        String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

// ─── Testimonials ─────────────────────────────────────────────
model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  company    String?
  role       String?
  avatarUrl  String?
  content    String   @db.Text
  rating     Int      @default(5)
  eventType  String?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

// ─── Admin Logs ──────────────────────────────────────────────
model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
}

// ─── Promotions ──────────────────────────────────────────────
model Promotion {
  id           String   @id @default(cuid())
  code         String   @unique
  description  String?
  discount     Decimal  @db.Decimal(5, 2)
  isPercentage Boolean  @default(true)
  minOrder     Decimal? @db.Decimal(10, 2)
  usageLimit   Int?
  usageCount   Int      @default(0)
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}
